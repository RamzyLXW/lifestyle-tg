node_modules/
dist/
cache/

# состояние постинга (published_at + одобрения) — коммитим для CI;
# WAL/SHM (-wal/-shm) НЕ коммитим
*.db
!shevchenko.db
*.db-*

# секреты не коммитим
*.serviceaccount.json
*-*.iam.gserviceaccount.com.json
steady-habitat-*.json
